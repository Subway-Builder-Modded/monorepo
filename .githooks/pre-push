#!/usr/bin/env sh
set -eu

ROOT_DIR="$(git rev-parse --show-toplevel)"

is_null_sha() { [ -z "$(printf '%s' "$1" | tr -d '0')" ]; }

run_railyard_checks() {
  RAILYARD_DIR="$ROOT_DIR/railyard"
  if [ ! -d "$RAILYARD_DIR" ]; then
    return 0
  fi

  if command -v pwsh >/dev/null 2>&1; then
    pwsh -NoProfile -ExecutionPolicy Bypass -File "$RAILYARD_DIR/scripts/pre-push-check.ps1"
  elif command -v powershell >/dev/null 2>&1; then
    powershell -NoProfile -ExecutionPolicy Bypass -File "$RAILYARD_DIR/scripts/pre-push-check.ps1"
  else
    "$RAILYARD_DIR/scripts/pre-push-check.sh"
  fi
}

run_website_checks() {
  WEBSITE_DIR="$ROOT_DIR/website"
  if [ ! -d "$WEBSITE_DIR" ] || [ ! -f "$WEBSITE_DIR/package.json" ]; then
    return 0
  fi

  if command -v pwsh >/dev/null 2>&1; then
    pwsh -NoProfile -ExecutionPolicy Bypass -File "$WEBSITE_DIR/scripts/quality.ps1"
  elif command -v powershell >/dev/null 2>&1; then
    powershell -NoProfile -ExecutionPolicy Bypass -File "$WEBSITE_DIR/scripts/quality.ps1"
  else
    "$WEBSITE_DIR/scripts/quality.sh"
  fi
}

needs_railyard=0
needs_website=0

while read -r local_ref local_sha remote_ref remote_sha; do
  if is_null_sha "$local_sha"; then
    # Branch being deleted — nothing to check.
    continue
  fi

  if is_null_sha "$remote_sha"; then
    # New branch: diff against merge-base with main, falling back to root commit.
    if ! base="$(git merge-base "$local_sha" origin/main 2>/dev/null)"; then
      base="$(git rev-list --max-parents=0 "$local_sha" | tail -1)"
    fi
  else
    base="$remote_sha"
  fi

  changed="$(git diff --name-only "$base" "$local_sha")"

  if echo "$changed" | grep -q "^railyard/"; then needs_railyard=1; fi
  if echo "$changed" | grep -q "^website/"; then needs_website=1; fi
done

if [ "$needs_railyard" = "1" ]; then run_railyard_checks; fi
if [ "$needs_website" = "1" ]; then run_website_checks; fi
