{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-nova",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/styles/global.css",
    "baseColor": "zinc",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "bold",
  "aliases": {
    "components": "@/shared",
    "utils": "@/lib/utils",
    "ui": "@/shared/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@diceui": "https://diceui.com/r/{name}.json",
    "@kibo-ui": "https://www.kibo-ui.com/r/{name}.json",
    "@intentui": "https://intentui.com/r/{name}",
    "@eldoraui": "https://eldoraui.site/r/{name}.json"
  }
}
