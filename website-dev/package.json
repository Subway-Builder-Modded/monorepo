{
  "name": "subway-builder-modded-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "generate:github-release-cache": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-github-release-cache.mjs",
    "generate:registry-analytics-cache": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-registry-analytics-cache.mjs",
    "generate:railyard-analytics-cache": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-railyard-analytics-cache.mjs",
    "generate:map-data-cache": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-map-data-cache.mjs",
    "generate:website-analytics": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-website-analytics.mjs",
    "analytics": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-github-release-cache.mjs && node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-registry-analytics-cache.mjs && node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-railyard-analytics-cache.mjs && node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-map-data-cache.mjs && node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-website-analytics.mjs",
    "test": "vp test run --passWithNoTests",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage --passWithNoTests",
    "format": "vp fmt \"**/*.{ts,tsx,mdx}\"",
    "format:check": "vp fmt --check \"**/*.{ts,tsx,mdx}\"",
    "lint": "vp lint --max-warnings=0 app tests vite.config.ts vitest.config.ts",
    "lint:fix": "vp lint --max-warnings=0 --fix app tests vite.config.ts vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run format:check && pnpm run test && pnpm run test:coverage",
    "ci": "pnpm run lint:fix && pnpm run format"
  },
