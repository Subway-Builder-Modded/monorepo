    "@subway-builder-modded/lifecycle-web": "workspace:*",
    "@subway-builder-modded/shared-ui": "workspace:*",
    "@subway-builder-modded/stores-core": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
