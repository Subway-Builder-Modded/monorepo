{
  "name": "subway-builder-modded-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "fetch": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/fetch-registry-site-data.mjs",
    "generate:github-release-cache": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/generate-github-release-cache.mjs",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "vp fmt .",
    "format:check": "vp fmt --check .",
    "lint": "vp lint --max-warnings=0 .",
    "lint:fix": "vp lint --max-warnings=0 --fix .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test && pnpm run test:coverage",
    "ci": "pnpm run typecheck && pnpm run lint:fix && pnpm run format && pnpm run test && pnpm run test:coverage",
    "ci:no-tests": "pnpm run typecheck && pnpm run lint:fix && pnpm run format"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@subway-builder-modded/analytics": "workspace:*",
    "@subway-builder-modded/asset-listings-state": "workspace:*",
    "@subway-builder-modded/config": "workspace:^",
    "@subway-builder-modded/icons": "workspace:*",
    "@subway-builder-modded/mdx": "workspace:*",
    "@subway-builder-modded/shared-ui": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-emoji": "^1.0.3",
    "country-flag-icons": "^1.6.17",
    "embla-carousel-react": "^8.6.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "lucide-react": "^1.16.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.40.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "recharts": "^2.15.4",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shadcn": "^3.8.5",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^26.1.0",
    "rehype-pretty-code": "^0.14.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vite-plus": "catalog:",
    "vitest": "^4.1.7"
  }
}
