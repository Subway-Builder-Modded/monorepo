      "default": "./src/theme-script.ts"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "vitest": "^4.1.4"
  }
}
